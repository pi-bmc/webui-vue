# Demo mode: run the UI with no backend.
#   npm run demo   ->   http://localhost:8000
#
# Seeds authentication (skips login) and serves mock Redfish data from
# src/mocks/. Only active in this mode; never affects dev/build.
VITE_DEMO_MODE=true

# Serve over plain HTTP so there's no self-signed-cert prompt for the demo.
DEV_HTTPS=false
